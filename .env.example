# Smart Travel Planner Agent Environment Configuration

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Google APIs
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Weather APIs
WEATHER_API_KEY=your_openweathermap_api_key_here
OPENAQ_API_KEY=your_openaq_api_key_here

# Amadeus Travel APIs
AMADEUS_API_KEY=your_amadeus_client_id_here
AMADEUS_API_SECRET=your_amadeus_client_secret_here
AMADEUS_CHECKIN_OFFSET_DAYS=7
AMADEUS_STAY_NIGHTS=1

# Security Settings
REQUESTS_CA_BUNDLE=
SSL_VERIFY=true

# Open-Meteo Settings
OPENMETEO_FORCE_JSON=0
OPENMETEO_AUTO_ACCEPT_UNVERIFIED=0
OPENMETEO_ALLOW_INSECURE=0
OPENMETEO_CAPTURE_CHAIN=0
OPENMETEO_CHAIN_FILE=openmeteo_cert.pem

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Database (if using external database)
# DATABASE_URL=postgresql://user:password@localhost:5432/travel_planner
# REDIS_URL=redis://localhost:6379/0

# Monitoring
# SENTRY_DSN=your_sentry_dsn_here
# PROMETHEUS_PORT=9090
